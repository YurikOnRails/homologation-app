# ─── Space for Edu — Environment Variables ───────────────────────────────────
# These values are exposed to the browser (VITE_ prefix).
#
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values below.
#   3. See DEPLOY_GUIDE.md for detailed instructions.
#
# CHECK: Run  bin/check_deploy_ready  to verify everything is configured.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Contacts (shown on the website) ─────────────────────────────────────────
VITE_CONTACT_WHATSAPP=34600000000
VITE_CONTACT_EMAIL=your-email@example.com
VITE_SUPPORT_EMAIL=support@example.com
VITE_CONTACT_TELEGRAM=your_telegram_handle

# ─── Stripe — Paid consultation (100 €) ──────────────────────────────────────
# Create a Payment Link in Stripe Dashboard → Payment Links.
# Set redirect after payment to: https://yourdomain.com/es/consultation-thank-you
# Paste the link URL below (e.g. https://buy.stripe.com/abc123...).
# If left empty, the consultation button will fall back to WhatsApp.
VITE_STRIPE_CONSULTATION_LINK=https://buy.stripe.com/REPLACE_ME
